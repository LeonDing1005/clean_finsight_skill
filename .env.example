# ============================================
# FinSight Research — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit API keys.

# ---- Required: LLM API ----
DS_MODEL_NAME=deepseek-chat
DS_BASE_URL=https://api.deepseek.com/v1
DS_API_KEY=sk-your-api-key-here

# ---- Optional: VLM for chart critique ----
# VLM_MODEL_NAME=gpt-4o
# VLM_BASE_URL=https://api.openai.com/v1
# VLM_API_KEY=sk-your-vlm-key-here

# ---- Optional: Embedding model for semantic search ----
# EMBEDDING_MODEL_NAME=text-embedding-3-small
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-your-embedding-key-here

# ---- Optional: Web Search APIs ----
# SERPER_API_KEY=your-serper-key-here
# BOCHAAI_API_KEY=your-bocha-key-here

# ---- Optional: US macroeconomic data ----
